CREATE OR REPLACE FUNCTION get_next_sequence(
  p_entity_type VARCHAR,
  p_warehouse_code VARCHAR,
  p_date DATE
) RETURNS INTEGER AS $$
DECLARE
  v_sequence INTEGER;
BEGIN
  INSERT INTO "Sequence" ("entity_type", "warehouse_code", "sequence_date", "last_number")
  VALUES (p_entity_type, p_warehouse_code, p_date, 1)
  ON CONFLICT ("entity_type", "warehouse_code", "sequence_date")
  DO UPDATE SET "last_number" = "Sequence"."last_number" + 1
  RETURNING "last_number" INTO v_sequence;

  RETURN v_sequence;
END;
$$ LANGUAGE plpgsql;